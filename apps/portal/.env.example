# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=

# CORS allow-origin for kiosk API routes (Plan 6a). Defaults to
# http://localhost:5173 if unset; set to the deployed kiosk URL in production.
KIOSK_ORIGIN=

# Twilio (voice path — Plan 5a/5b). See docs/setup/2026-05-30-twilio-voice-setup.md
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Cron auth (Vercel sends "Authorization: Bearer $CRON_SECRET"). Optional locally.
CRON_SECRET=

# Self-hosted LiveKit (Phase 4). Required.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Kiosk config-token signing secret (Plan 6a). Any long random string.
KIOSK_CONFIG_SECRET=

# Number dialed for an in-call emergency (Plan 6c). 933 = E911 address-readback
# TEST number (never reaches a PSAP). Use 933 for ALL dev/test. Set to 911 ONLY
# in production. Defaults to 911 if unset.
EMERGENCY_DIAL_NUMBER=933

# --- Sentry (optional; SDK no-ops if DSN is unset) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Server/build only — never expose. project:read + project:releases scopes.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=lobby-connect
SENTRY_PROJECT=portal

# Speechmatics live captions (v1.1). Server-only — minted into short-lived
# browser JWTs by /api/captions/token. See docs/plans/2026-06-25-v1.1-live-captions.md
SPEECHMATICS_API_KEY=

# Web Push (VAPID) — generate once with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
